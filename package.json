{
  "name": "real-estate-platform",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "dev": "concurrently -n server,web -c blue,green \"npm:dev:server\" \"npm:dev:web\"",
    "dev:server": "npm run dev -w @rep/server",
    "dev:web": "npm run dev -w @rep/web",
    "build": "npm run build -w @rep/web",
    "typecheck": "tsc -p packages/shared && tsc -p apps/server && tsc -p apps/web",
    "seed": "npm run seed -w @rep/server"
  },
  "devDependencies": {
    "concurrently": "^9.1.0",
    "typescript": "^5.7.2"
  }
}
