# ──────────────────────────────────────────────────────────────────────────
# Real Estate Discovery & Offer Platform — environment
# Everything below is OPTIONAL. With no values set, the app runs fully on the
# mock-first stack (in-memory seeded store + deterministic AI fallback).
# ──────────────────────────────────────────────────────────────────────────

# Build re-targeting flags (see packages/shared/src/config.ts)
TARGET_BUYER=first_time_buyer        # first_time_buyer | investor | luxury | rental
MARKET=jamaica                       # jamaica | caribbean | us | generic

# Server
PORT=8787
# Secret used to encrypt sensitive buyer_profile fields at rest in the mock store.
# In production (Supabase) this is handled by pgcrypto instead.
PROFILE_ENCRYPTION_KEY=dev-only-change-me-32byteslong-secret

# Anthropic Claude — server-side only. If unset, the Negotiation Coach uses a
# deterministic mock that reasons from the same structured signals.
ANTHROPIC_API_KEY=

# Supabase — inactive until all three are set. When present, the Supabase
# providers replace the mock store.
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Web (Vite) — base URL of the API
VITE_API_BASE=http://localhost:8787
